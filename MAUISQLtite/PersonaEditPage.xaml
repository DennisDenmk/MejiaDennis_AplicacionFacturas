<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MAUISQLtite.PersonaEditPage"
             Title="Formulario de Persona"
             BackgroundColor="{AppThemeBinding Light=#F8F9FA, Dark=#121212}">

    <ScrollView>
        <VerticalStackLayout Spacing="15" Padding="20" VerticalOptions="Start">
            <Label x:Name="PageTitleLabel" 
                   Text="Nueva Persona" 
                   FontSize="24" 
                   FontAttributes="Bold" 
                   TextColor="{AppThemeBinding Light=Black, Dark=White}" 
                   Margin="0,0,0,10" />

            <!-- Nombre -->
            <VerticalStackLayout Spacing="5">
                <Label Text="Nombre *" 
                       FontSize="14" 
                       FontAttributes="Bold" 
                       TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                <Entry x:Name="NombreEntry" 
                       Placeholder="Escriba el nombre completo" 
                       BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}" 
                       TextColor="{AppThemeBinding Light=Black, Dark=White}" 
                       HeightRequest="45" />
            </VerticalStackLayout>

            <!-- Email -->
            <VerticalStackLayout Spacing="5">
                <Label Text="Correo Electrónico" 
                       FontSize="14" 
                       FontAttributes="Bold" 
                       TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                <Entry x:Name="EmailEntry" 
                       Placeholder="ejemplo@correo.com" 
                       Keyboard="Email"
                       BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}" 
                       TextColor="{AppThemeBinding Light=Black, Dark=White}" 
                       HeightRequest="45" />
            </VerticalStackLayout>

            <!-- Teléfono -->
            <VerticalStackLayout Spacing="5">
                <Label Text="Teléfono" 
                       FontSize="14" 
                       FontAttributes="Bold" 
                       TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                <Entry x:Name="TelefonoEntry" 
                       Placeholder="Número telefónico" 
                       Keyboard="Telephone"
                       BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}" 
                       TextColor="{AppThemeBinding Light=Black, Dark=White}" 
                       HeightRequest="45" />
            </VerticalStackLayout>

            <!-- Botones -->
            <Grid ColumnDefinitions="*, *" ColumnSpacing="15" Margin="0,20,0,0">
                <Button Grid.Column="0" 
                        Text="Cancelar" 
                        Clicked="OnCancelClicked" 
                        BackgroundColor="Gray" 
                        TextColor="White" 
                        HeightRequest="45" 
                        CornerRadius="8" />
                <Button Grid.Column="1" 
                        Text="Guardar" 
                        Clicked="OnSaveClicked" 
                        BackgroundColor="#512BD4" 
                        TextColor="White" 
                        HeightRequest="45" 
                        CornerRadius="8" />
            </Grid>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
