<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:MAUISQLtite"
             x:Class="MAUISQLtite.PersonaDetailPage"
             Title="Detalle de Persona"
             BackgroundColor="{AppThemeBinding Light=#F8F9FA, Dark=#121212}">

    <Grid RowDefinitions="Auto, Auto, *">
        <!-- 1. Persona Info Section (Master) -->
        <Border Grid.Row="0"
                StrokeShape="RoundRectangle 8"
                StrokeThickness="1"
                Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#2C2C2C}"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                Margin="15,15,15,10"
                Padding="15">
            <VerticalStackLayout Spacing="10">
                <Label x:Name="NombreLabel" 
                       FontSize="22" 
                       FontAttributes="Bold" 
                       TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                
                <Grid ColumnDefinitions="Auto, *" RowDefinitions="Auto, Auto" RowSpacing="5" ColumnSpacing="10">
                    <Label Grid.Row="0" Grid.Column="0" Text="Correo:" FontAttributes="Bold" TextColor="Gray" />
                    <Label Grid.Row="0" Grid.Column="1" x:Name="EmailLabel" TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                    <Label Grid.Row="1" Grid.Column="0" Text="Teléfono:" FontAttributes="Bold" TextColor="Gray" />
                    <Label Grid.Row="1" Grid.Column="1" x:Name="TelefonoLabel" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </Grid>

                <Grid ColumnDefinitions="*, *" ColumnSpacing="10" Margin="0,10,0,0">
                    <Button Grid.Column="0" 
                            Text="Editar Datos" 
                            Clicked="OnEditPersonaClicked" 
                            BackgroundColor="#2196F3" 
                            TextColor="White" 
                            HeightRequest="38" 
                            CornerRadius="5" />
                    <Button Grid.Column="1" 
                            Text="Eliminar Persona" 
                            Clicked="OnDeletePersonaClicked" 
                            BackgroundColor="#F44336" 
                            TextColor="White" 
                            HeightRequest="38" 
                            CornerRadius="5" />
                </Grid>
            </VerticalStackLayout>
        </Border>

        <!-- 2. Facturas Header Section -->
        <Grid Grid.Row="1" ColumnDefinitions="*, Auto" Margin="15,10,15,5" VerticalOptions="Center">
            <Label Grid.Column="0" 
                   Text="Facturas" 
                   FontSize="20" 
                   FontAttributes="Bold" 
                   TextColor="{AppThemeBinding Light=Black, Dark=White}" 
                   VerticalOptions="Center" />
            <Button Grid.Column="1" 
                    Text="+ Agregar Factura" 
                    Clicked="OnAddFacturaClicked" 
                    BackgroundColor="#4CAF50" 
                    TextColor="White" 
                    HeightRequest="38" 
                    CornerRadius="5" />
        </Grid>

        <!-- 3. Facturas List (Detail) -->
        <CollectionView x:Name="FacturasCollectionView"
                        Grid.Row="2"
                        SelectionMode="None"
                        Margin="15,0,15,15">
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="5" Padding="30">
                    <Label Text="No hay facturas registradas"
                           FontSize="16"
                           FontAttributes="Italic"
                           HorizontalOptions="Center"
                           TextColor="Gray" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="local:Factura">
                    <Border StrokeShape="RoundRectangle 8"
                            StrokeThickness="1"
                            Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#2C2C2C}"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                            Margin="0,0,0,10"
                            Padding="12">
                        <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto">
                            <!-- Left: Invoice Details -->
                            <VerticalStackLayout Grid.Column="0" Grid.RowSpan="2" Spacing="3" VerticalOptions="Center">
                                <HorizontalStackLayout Spacing="8">
                                    <Label Text="Nº:" FontAttributes="Bold" TextColor="Gray" FontSize="14" />
                                    <Label Text="{Binding NumeroFactura}" FontAttributes="Bold" FontSize="14" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                                </HorizontalStackLayout>
                                <Label Text="{Binding Concepto}" FontSize="14" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                                <Label Text="{Binding Fecha, StringFormat='{0:dd/MM/yyyy}'}" FontSize="12" TextColor="Gray" />
                            </VerticalStackLayout>

                            <!-- Right Top: Amount -->
                            <Label Grid.Column="1" Grid.Row="0" 
                                   Text="{Binding Monto, StringFormat='${0:F2}'}" 
                                   FontSize="16" 
                                   FontAttributes="Bold" 
                                   TextColor="#2E7D32" 
                                   HorizontalOptions="End" 
                                   VerticalOptions="Center" />

                            <!-- Right Bottom: Actions -->
                            <HorizontalStackLayout Grid.Column="1" Grid.Row="1" Spacing="8" Margin="0,5,0,0" HorizontalOptions="End" VerticalOptions="Center">
                                <Button Text="Editar"
                                        Clicked="OnEditFacturaClicked"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="#2196F3"
                                        TextColor="White"
                                        HeightRequest="30"
                                        Padding="8,0"
                                        FontSize="12"
                                        CornerRadius="4" />
                                <Button Text="Eliminar"
                                        Clicked="OnDeleteFacturaClicked"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="#F44336"
                                        TextColor="White"
                                        HeightRequest="30"
                                        Padding="8,0"
                                        FontSize="12"
                                        CornerRadius="4" />
                            </HorizontalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
